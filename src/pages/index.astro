---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { productos, categorias } from '../lib/productos';
import { buildWhatsAppUrl } from '../lib/whatsapp';

const destacados = productos.filter((p) => p.destacado);
const whatsappUrl = buildWhatsAppUrl('Hola, quisiera consultar sobre los muebles de El Rústico.');
---

<BaseLayout title="El Rústico">
  <section class="relative overflow-hidden bg-rustico-800 text-white">
    <div class="absolute inset-0 opacity-20">
      <img
        src="https://images.unsplash.com/photo-1616046229475-7dca48d38fc0?w=1600&q=80"
        alt=""
        class="h-full w-full object-cover"
      />
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 md:px-6 md:py-32">
      <p class="text-sm font-semibold uppercase tracking-widest text-rustico-300">San José de Metán, Salta</p>
      <h1 class="mt-4 max-w-2xl font-serif text-4xl font-bold leading-tight md:text-6xl">
        Muebles con alma rústica para tu hogar
      </h1>
      <p class="mt-6 max-w-xl text-lg text-rustico-200">
        Piezas artesanales en madera, diseñadas con estilo campestre y la calidez del norte argentino.
        Consultá disponibilidad y precios por WhatsApp.
      </p>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a href="/catalogo" class="btn-primary bg-white text-rustico-800 hover:bg-rustico-100">
          Ver catálogo
        </a>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          Escribinos por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 md:px-6">
    <div class="text-center">
      <h2 class="section-title">Categorías</h2>
      <p class="section-subtitle">Encontrá el mueble perfecto para cada rincón de tu casa</p>
    </div>
    <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {categorias.map((cat) => (
        <a
          href={`/catalogo?categoria=${encodeURIComponent(cat)}`}
          class="group rounded-2xl border border-rustico-200 bg-white p-6 text-center shadow-sm transition hover:border-rustico-400 hover:shadow-md"
        >
          <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-rustico-100 text-rustico-700 transition group-hover:bg-rustico-700 group-hover:text-white">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <span class="text-sm font-semibold text-rustico-800">{cat}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-rustico-100 py-16">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
        <div>
          <h2 class="section-title">Destacados</h2>
          <p class="section-subtitle">Nuestras piezas más consultadas</p>
        </div>
        <a href="/catalogo" class="btn-outline">Ver todo el catálogo</a>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {destacados.map((producto) => (
          <ProductCard producto={producto} />
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 md:px-6">
    <div class="grid items-center gap-10 md:grid-cols-2">
      <div>
        <h2 class="section-title">Hecho en Metán, con dedicación</h2>
        <p class="mt-4 leading-relaxed text-rustico-600">
          En El Rústico trabajamos cada pieza con maderas seleccionadas y terminaciones que
          realzan la belleza natural del material. Nuestro estilo combina lo artesanal con
          la funcionalidad que tu hogar necesita.
        </p>
        <a href="/nosotros" class="btn-primary mt-6">Conocenos</a>
      </div>
      <div class="overflow-hidden rounded-2xl">
        <img
          src="https://images.unsplash.com/photo-1615876231816-7b2c4b0e0e0e?w=800&q=80"
          alt="Taller de muebles artesanales"
          class="h-72 w-full object-cover md:h-96"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="bg-oliva-700 py-16 text-white">
    <div class="mx-auto max-w-3xl px-4 text-center md:px-6">
      <h2 class="font-serif text-3xl font-bold md:text-4xl">¿Tenés dudas sobre un mueble?</h2>
      <p class="mt-4 text-lg text-rustico-200">
        Escribinos por WhatsApp y te asesoramos con medidas, materiales y opciones de personalización.
      </p>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp mt-8">
        Chatear por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>
