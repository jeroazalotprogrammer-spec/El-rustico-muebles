---
import BaseLayout from '../layouts/BaseLayout.astro';
import CatalogoApp from '../components/react/CatalogoApp';
import { fetchProductos, isNeonConfigured } from '../lib/db';

export const prerender = false;

const categoriaFiltro = Astro.url.searchParams.get('categoria');
const productos = await fetchProductos();
const categorias = [...new Set(productos.map((p) => p.categoria))].sort();
const dataSource = isNeonConfigured() ? 'neon' : 'json';
---

<BaseLayout
  title="Catálogo de Muebles Rústicos"
  description="Catálogo de muebles rústicos artesanales en San José de Metán, Salta. Sofás, mesas, sillas, dormitorio y decoración en madera. Consultá por WhatsApp."
>
  <section class="bg-rustico-800 py-12 text-white md:py-16">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <h1 class="font-serif text-3xl font-bold md:text-5xl">Catálogo de muebles en Metán, Salta</h1>
      <p class="mt-3 max-w-xl text-rustico-300">
        Explorá nuestra colección con búsqueda y filtros. Consultá precio y disponibilidad por WhatsApp.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6">
    <CatalogoApp
      client:only="react"
      productos={productos}
      categorias={categorias}
      initialCategoria={categoriaFiltro}
      dataSource={dataSource}
    />
  </section>
</BaseLayout>
