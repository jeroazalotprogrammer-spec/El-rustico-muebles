---
import { formatPrecio } from '../lib/productos';
import { buildWhatsAppUrl, productWhatsAppMessage } from '../lib/whatsapp';
import type { Producto } from '../lib/productos';

interface Props {
  producto: Producto;
}

const { producto } = Astro.props;
const whatsappUrl = buildWhatsAppUrl(productWhatsAppMessage(producto.nombre));
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-rustico-200 bg-white shadow-sm transition hover:shadow-md">
  <a href={`/producto/${producto.slug}`} class="relative block aspect-[4/3] overflow-hidden bg-rustico-100">
    <img
      src={producto.imagen}
      alt={producto.nombre}
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <span class="absolute left-3 top-3 rounded-full bg-white/90 px-3 py-1 text-xs font-medium text-rustico-700">
      {producto.categoria}
    </span>
  </a>

  <div class="flex flex-1 flex-col p-5">
    <a href={`/producto/${producto.slug}`}>
      <h3 class="font-serif text-lg font-semibold text-rustico-800 transition group-hover:text-rustico-600">
        {producto.nombre}
      </h3>
    </a>
    <p class="mt-2 line-clamp-2 flex-1 text-sm text-rustico-600">{producto.descripcion}</p>

    <div class="mt-4 flex items-center justify-between gap-3">
      {producto.precioConsultar || producto.precio === null ? (
        <span class="text-sm font-semibold text-terracota-600">Consultar precio</span>
      ) : (
        <span class="text-lg font-bold text-rustico-800">{formatPrecio(producto.precio)}</span>
      )}
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-whatsapp shrink-0 px-4 py-2 text-xs"
        aria-label={`Consultar ${producto.nombre} por WhatsApp`}
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Consultar
      </a>
    </div>
  </div>
</article>
