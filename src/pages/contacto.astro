---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildWhatsAppUrl, WHATSAPP_DISPLAY } from '../lib/whatsapp';
import { SITE } from '../lib/site';

const whatsappUrl = buildWhatsAppUrl('Hola, quisiera hacer una consulta sobre los muebles de El Rústico.');
const whatsappCatalogo = buildWhatsAppUrl('Hola, me gustaría ver el catálogo de muebles disponibles.');
---

<BaseLayout
  title="Contacto"
  description={`Contactá a ${SITE.name} por WhatsApp. Muebles rústicos en ${SITE.ubicacionCompleta}. Consultá precios, medidas y envíos.`}
>
  <section class="bg-rustico-800 py-12 text-white md:py-16">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <h1 class="font-serif text-3xl font-bold md:text-5xl">Contacto en {SITE.ciudad}, {SITE.provincia}</h1>
      <p class="mt-3 max-w-xl text-rustico-300">
        Estamos en {SITE.ubicacionCompleta}. La forma más rápida de consultar muebles rústicos es por WhatsApp.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 md:px-6">
    <div class="grid gap-10 lg:grid-cols-2">
      <div class="space-y-6">
        <div class="rounded-2xl border border-rustico-200 bg-white p-6 shadow-sm">
          <h2 class="font-serif text-xl font-semibold text-rustico-800">WhatsApp</h2>
          <p class="mt-2 text-rustico-600">La vía preferida para consultas, precios y disponibilidad.</p>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp mt-4 w-full sm:w-auto">
            {WHATSAPP_DISPLAY}
          </a>
        </div>

        <div class="rounded-2xl border border-rustico-200 bg-white p-6 shadow-sm">
          <h2 class="font-serif text-xl font-semibold text-rustico-800">Ubicación</h2>
          <p class="mt-2 text-rustico-600">
            {SITE.ciudad}<br />
            {SITE.provincia}, {SITE.pais}
          </p>
        </div>

        <div class="rounded-2xl border border-rustico-200 bg-white p-6 shadow-sm">
          <h2 class="font-serif text-xl font-semibold text-rustico-800">Horarios de atención</h2>
          <p class="mt-2 text-rustico-600">{SITE.horarios}</p>
          <p class="mt-2 text-sm text-rustico-500">
            Fuera de horario podés dejarnos un mensaje por WhatsApp y te respondemos a la brevedad.
          </p>
        </div>

        <div class="rounded-2xl border border-rustico-200 bg-white p-6 shadow-sm">
          <h2 class="font-serif text-xl font-semibold text-rustico-800">¿Cómo comprar?</h2>
          <ol class="mt-3 list-inside list-decimal space-y-2 text-sm text-rustico-600">
            <li>Explorá el catálogo en la web</li>
            <li>Elegí el producto que te interese</li>
            <li>Tocá "Consultar" para escribirnos por WhatsApp</li>
            <li>Coordinamos detalles, precio y entrega</li>
          </ol>
        </div>
      </div>

      <div class="flex flex-col justify-center rounded-2xl bg-rustico-100 p-8 md:p-12">
        <h2 class="font-serif text-2xl font-bold text-rustico-800">¿Listo para empezar?</h2>
        <p class="mt-4 text-rustico-600">
          Mandanos un mensaje y te respondemos a la brevedad. Podés preguntar por medidas,
          colores, materiales o pedir asesoramiento para tu espacio.
        </p>
        <div class="mt-6 flex flex-col gap-3">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
            Enviar mensaje
          </a>
          <a href={whatsappCatalogo} target="_blank" rel="noopener noreferrer" class="btn-outline">
            Pedir catálogo completo
          </a>
          <a href="/catalogo" class="text-center text-sm font-medium text-rustico-700 underline underline-offset-2 hover:text-rustico-900">
            O explorá el catálogo online
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
